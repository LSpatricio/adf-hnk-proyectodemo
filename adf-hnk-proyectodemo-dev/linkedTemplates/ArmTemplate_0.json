		},
		"LS_KV_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-hnk-proyectodemo-dev.vault.azure.net/"
		},
		"LS_SFTP_XCARET_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "ftp.cloud.varicent.com"
		},
		"LS_SFTP_XCARET_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "xcaretdemodev"
		},
		"AzureBlobStorage269_properties_privateLinkResourceId": {
			"type": "string",
			"defaultValue": "/subscriptions/b2b90ae2-21ac-4983-9392-d9cbb1910c64/resourceGroups/rg-hnk-proyectodemo-tgv-dev/providers/Microsoft.Storage/storageAccounts/sthnkproyectodemodev"
